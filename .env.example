SARVAM_API_KEY=sk_xxx
RETELL_API_KEY=key_xxx
EXOTEL_API_KEY=xxx
EXOTEL_API_TOKEN=xxx
EXOTEL_ACCOUNT_SID=your_exotel_sid
DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/shopify_app
RETELL_AGENT_ID=
NODE_ENV=production
PORT=3104

# Shopify webhook verification — multi-store aware.
# Every store has its own app in the Shopify Dev Dashboard, with its own
# Client Secret. Use the JSON map keyed by myshopify domain (matches the
# X-Shopify-Shop-Domain header the webhook sends):
#
#   SHOPIFY_WEBHOOK_SECRETS='{"f51039.myshopify.com":"shpss_xxx","acmsuy-g0.myshopify.com":"shpss_yyy"}'
#
# The per-shop map is checked first. SHOPIFY_WEBHOOK_SECRET (singular) is a
# fallback for shops not in the map — leave empty in production multi-store
# setups so misconfigured shops fail loudly instead of silently using a
# wrong-but-present secret.
SHOPIFY_WEBHOOK_SECRETS={}
SHOPIFY_WEBHOOK_SECRET=

# Brand the agent speaks on behalf of. Flows into both the Hindi and English
# prompts and the welcome line. For multi-tenant deployments, leave these
# blank and pass order.storeName / order.storeCategory to triggerLivekitCall
# (or set them on a per-shop metafield and resolve at dispatch time).
STORE_NAME=Your Store
STORE_CATEGORY=online store

# Shared secret authenticating the LiveKit agent worker → Express tool webhooks
# at /webhook/livekit/tool/*. Must be identical in the agent worker's env and
# the server's env. If unset, those endpoints fail closed.
LIVEKIT_TOOL_SECRET=change-me-to-a-random-32-byte-hex

# ── Training-data moat: audio egress + consent ──────────────────────────
# Recording disclosure played as the last line of the welcome ("this call may
# be recorded ..."). Set to "off" only if your deployment captures consent
# out-of-band (e.g. on the Shopify checkout page).
RECORDING_CONSENT_DISCLOSURE=on

# Cloud storage for room-composite audio egress. If RECORDING_BACKEND is
# unset, no audio is captured — transcripts still persist to Postgres.
# Backends: "r2" (recommended) | "gcp" | "s3" | "" (off)
#
# Why r2 is the default recommendation: Cloudflare R2 has $0 egress fees,
# which matters because training pulls the whole dataset back to a GPU box.
# At our volume (hundreds to tens of thousands of calls/mo) the storage
# itself is free on R2's 10GB tier, and egress-during-training is $0
# versus ~$0.12/GB on GCS or ~$0.09/GB on S3.
RECORDING_BACKEND=r2
RECORDING_BUCKET=
RECORDING_PREFIX=cod-confirm/

# ── R2 backend (recommended) ──────────────────────────────────────────
# 1. Create a Cloudflare account (free tier is plenty).
# 2. R2 dashboard → Create bucket (e.g. "glitch-cod-recordings").
#    Set RECORDING_BUCKET to that bucket name.
# 3. R2 dashboard → Manage API Tokens → Create "Object Read & Write"
#    token scoped to just this bucket. Copy the Access Key ID + Secret.
# 4. Copy your account ID from the R2 dashboard URL (32-char hex).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── GCP backend (alternative — higher egress cost during training) ────
# Paste the full service-account JSON as a single-line string OR leave
# blank to use the host's default service account.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ── AWS S3 backend (alternative — even higher egress cost) ────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
